# Database Configuration
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech:5432/localai_leads?sslmode=require

# Authentication
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Business Copilot (Optional - for enhanced insights)
# Three modes available:
# 1. Template Mode (FREE) - No setup needed, good quality
# 2. Ollama Mode (FREE) - Local AI, best quality without cost
# 3. ChatGPT Mode (Paid) - Cloud AI, ~$0.001 per lead

# Option 1: Use Ollama (FREE, local AI) - RECOMMENDED
USE_OLLAMA=true
OLLAMA_URL=http://localhost:11434

# Option 2: Use OpenAI ChatGPT (Paid, cloud AI)
# OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# If both are disabled, uses Template Mode (FREE)

# Payment Provider (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# External APIs
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Place Discovery Service Selection
# USE_LATLNG=true # Use LocationIQ/LatLng API (requires API key)
# Default: Google Places API (if above is false)
USE_LATLNG=false
LATLNG_API_KEY=your_latlng_api_key

# SMS Configuration (CRITICAL - REQUIRED FOR PLATFORM TO WORK)
# Without SMS, business owners cannot receive demo links!
SMS_ENABLED=true
SMS_PROVIDER=msg91  # Options: twilio, msg91, fast2sms

# MSG91 (Recommended for India - ₹0.15-0.25 per SMS)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=LOCALA

# Twilio (International - $0.0075 per SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Fast2SMS (India Budget - ₹0.10-0.15 per SMS)
FAST2SMS_API_KEY=your_fast2sms_api_key

# TRAI DLT Compliance (Required for India)
TRAI_DLT_ENTITY_ID=your_entity_id
TRAI_DLT_TEMPLATE_ID=your_template_id

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@localai-leads.com

# WhatsApp Business API (Optional)
WHATSAPP_BUSINESS_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Application Settings
ENVIRONMENT=development
DEBUG=True

